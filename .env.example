# Copy to .env and fill in real values — never commit .env
DB_HOST=localhost
DB_PORT=8889
DB_USER=poscafe
DB_PASSWORD=changeme
DB_NAME=poscafe

SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional: Evolution API for Phase 3 WhatsApp (customer store confirmations)
# EVOLUTION_API_URL=https://your-evolution-server.example
# EVOLUTION_API_KEY=your-api-key
# EVOLUTION_INSTANCE_NAME=coffee-shop
#
# If logs show "HTTPError 403" / "error code: 1010": often Cloudflare blocking API calls.
# Use your Evolution host URL that bypasses Cloudflare (direct IP / tunnel), or relax WAF for /message/*.

# Optional: legacy orders / staff paths — store customers pick Gulf country in UI
# WHATSAPP_DEFAULT_COUNTRY_CODE=973
# WHATSAPP_NATIONAL_NUMBER_LENGTH=8
